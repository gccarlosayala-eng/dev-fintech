<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- Make end_date nullable (RESCHEDULE action does not require it) -->
    <changeSet author="fineract" id="wcl-0016-1">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="m_wc_loan_delinquency_action" columnName="end_date"/>
        </preConditions>
        <dropNotNullConstraint tableName="m_wc_loan_delinquency_action" columnName="end_date" columnDataType="DATE"/>
    </changeSet>

    <!-- Add columns for RESCHEDULE action -->
    <changeSet author="fineract" id="wcl-0016-2">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_wc_loan_delinquency_action" columnName="minimum_payment"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_delinquency_action">
            <column name="minimum_payment" type="DECIMAL(19,6)"/>
            <column name="minimum_payment_type" type="VARCHAR(50)"/>
            <column name="frequency" type="INT"/>
            <column name="frequency_type" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

    <!-- Add version column for optimistic locking on delinquency range schedule -->
    <changeSet author="fineract" id="wcl-0016-3">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_wc_loan_delinquency_range_schedule" columnName="version"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_delinquency_range_schedule">
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
