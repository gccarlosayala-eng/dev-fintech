<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- Update existing NULL values to false and set column defaults for rolling deployment safety -->
    <changeSet author="fineract" id="wclp-0016-1">
        <update tableName="m_wc_loan_product_configurable_attributes">
            <column name="delinquency_bucket_classification_overridable" valueBoolean="false"/>
            <where>delinquency_bucket_classification_overridable IS NULL</where>
        </update>
        <update tableName="m_wc_loan_product_configurable_attributes">
            <column name="discount_default_overridable" valueBoolean="false"/>
            <where>discount_default_overridable IS NULL</where>
        </update>
        <update tableName="m_wc_loan_product_configurable_attributes">
            <column name="period_payment_frequency_overridable" valueBoolean="false"/>
            <where>period_payment_frequency_overridable IS NULL</where>
        </update>
        <update tableName="m_wc_loan_product_configurable_attributes">
            <column name="period_payment_frequency_type_overridable" valueBoolean="false"/>
            <where>period_payment_frequency_type_overridable IS NULL</where>
        </update>
    </changeSet>

    <!-- Set column defaults to false so old code inserting NULLs gets false during rolling deployment -->
    <changeSet author="fineract" id="wclp-0016-2">
        <addDefaultValue tableName="m_wc_loan_product_configurable_attributes"
                         columnName="delinquency_bucket_classification_overridable"
                         columnDataType="BOOLEAN"
                         defaultValueBoolean="false"/>
        <addDefaultValue tableName="m_wc_loan_product_configurable_attributes"
                         columnName="discount_default_overridable"
                         columnDataType="BOOLEAN"
                         defaultValueBoolean="false"/>
        <addDefaultValue tableName="m_wc_loan_product_configurable_attributes"
                         columnName="period_payment_frequency_overridable"
                         columnDataType="BOOLEAN"
                         defaultValueBoolean="false"/>
        <addDefaultValue tableName="m_wc_loan_product_configurable_attributes"
                         columnName="period_payment_frequency_type_overridable"
                         columnDataType="BOOLEAN"
                         defaultValueBoolean="false"/>
    </changeSet>

</databaseChangeLog>
