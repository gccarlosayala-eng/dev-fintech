<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="fineract" id="wcl-0019-1">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*)
                                         FROM m_external_event_configuration
                                         WHERE type = 'WorkingCapitalLoanDiscountFeeTransactionBusinessEvent'</sqlCheck>
        </preConditions>
        <insert tableName="m_external_event_configuration">
            <column name="type" value="WorkingCapitalLoanDiscountFeeTransactionBusinessEvent"/>
            <column name="enabled" valueBoolean="false"/>
        </insert>
    </changeSet>

    <changeSet id="1776330983335-1"
               author="soma">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_transaction_relation"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_transaction_relation">

            <column name="id"
                    type="BIGINT" autoIncrement="true">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_m_wc_loan_transaction_relation"/>
            </column>
            <column name="created_by"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="from_loan_transaction_id"
                    type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="to_loan_transaction_id"
                    type="BIGINT"/>
            <column name="relation_type_enum"
                    type="SMALLINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1776424461773-1" author="fineract" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_wc_loan_transaction_relation" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_transaction_relation">
            <column name="created_on_utc"
                    type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc"
                    type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1776424466408-1" author="fineract" context="mysql">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_wc_loan_transaction_relation" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_transaction_relation">
            <column name="created_on_utc"
                    type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc"
                    type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1776330983335-2"
               author="soma">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists
                        foreignKeyName="FK_M_WC_LOAN_TRANSACTION_RELATION_ON_FROM_LOAN_TRANSACTION"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="from_loan_transaction_id"
                                 baseTableName="m_wc_loan_transaction_relation"
                                 constraintName="FK_M_WC_LOAN_TRANSACTION_RELATION_ON_FROM_LOAN_TRANSACTION"
                                 referencedColumnNames="id"
                                 referencedTableName="m_wc_loan_transaction"/>
    </changeSet>
    <changeSet id="1776330983335-3"
               author="soma">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_M_WC_LOAN_TRANSACTION_RELATION_ON_TO_LOAN_TRANSACTION"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="to_loan_transaction_id"
                                 baseTableName="m_wc_loan_transaction_relation"
                                 constraintName="FK_M_WC_LOAN_TRANSACTION_RELATION_ON_TO_LOAN_TRANSACTION"
                                 referencedColumnNames="id"
                                 referencedTableName="m_wc_loan_transaction"/>
    </changeSet>

</databaseChangeLog>
