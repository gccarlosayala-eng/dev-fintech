<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- Add product FK to m_wc_loan (approved_principal already added by 0005_alter_wc_loan_add_columns.xml) -->
    <changeSet author="fineract" id="wcl-0014-1">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan"/>
            <not>
                <columnExists tableName="m_wc_loan" columnName="wc_loan_product_id"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan">
            <column name="wc_loan_product_id" type="BIGINT"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="wc_loan_product_id" baseTableName="m_wc_loan"
                                 constraintName="FK_wc_loan_product" deferrable="false" initiallyDeferred="false"
                                 referencedColumnNames="id" referencedTableName="m_wc_loan_product"/>
    </changeSet>

    <!-- Create delinquency range schedule table -->
    <changeSet author="fineract" id="wcl-0014-2">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_delinquency_range_schedule"/>
            </not>
        </preConditions>
        <createTable tableName="m_wc_loan_delinquency_range_schedule">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="wc_loan_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="period_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="from_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="to_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="expected_amount" type="DECIMAL(19,6)"/>
            <column name="paid_amount" type="DECIMAL(19,6)"/>
            <column name="outstanding_amount" type="DECIMAL(19,6)"/>
            <column name="min_payment_criteria_met" type="BOOLEAN"/>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Add UTC datetime columns for audit (MySQL) -->
    <changeSet author="fineract" id="wcl-0014-3" context="mysql">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_wc_loan_delinquency_range_schedule" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_delinquency_range_schedule">
            <column name="created_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add UTC datetime columns for audit (PostgreSQL) -->
    <changeSet author="fineract" id="wcl-0014-3-pg" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_wc_loan_delinquency_range_schedule" columnName="created_on_utc"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_delinquency_range_schedule">
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Foreign keys -->
    <changeSet author="fineract" id="wcl-0014-4">
        <addForeignKeyConstraint baseColumnNames="wc_loan_id" baseTableName="m_wc_loan_delinquency_range_schedule"
                                 constraintName="FK_wc_delinquency_range_schedule_loan" deferrable="false" initiallyDeferred="false"
                                 referencedColumnNames="id" referencedTableName="m_wc_loan"/>
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_wc_loan_delinquency_range_schedule"
                                 constraintName="FK_wc_delinquency_range_schedule_created_by" deferrable="false" initiallyDeferred="false"
                                 referencedColumnNames="id" referencedTableName="m_appuser"/>
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_wc_loan_delinquency_range_schedule"
                                 constraintName="FK_wc_delinquency_range_schedule_last_modified_by" deferrable="false"
                                 initiallyDeferred="false" referencedColumnNames="id" referencedTableName="m_appuser"/>
    </changeSet>

    <!-- Unique constraint and index -->
    <changeSet author="fineract" id="wcl-0014-5">
        <addUniqueConstraint tableName="m_wc_loan_delinquency_range_schedule"
                             columnNames="wc_loan_id, period_number"
                             constraintName="uc_wc_delinquency_range_schedule_loan_period"/>
        <createIndex tableName="m_wc_loan_delinquency_range_schedule" indexName="IND_wc_delinquency_range_schedule_loan_id">
            <column name="wc_loan_id"/>
        </createIndex>
    </changeSet>

    <!-- Add delinquent_days and delinquent_amount columns -->
    <changeSet author="fineract" id="wcl-0014-8">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_wc_loan_delinquency_range_schedule" columnName="delinquent_days"/>
            </not>
        </preConditions>
        <addColumn tableName="m_wc_loan_delinquency_range_schedule">
            <column name="delinquent_days" type="BIGINT"/>
            <column name="delinquent_amount" type="DECIMAL(19,6)"/>
        </addColumn>
    </changeSet>

    <!-- Register COB business step -->
    <changeSet author="fineract" id="wcl-0014-6">
        <insert tableName="m_batch_business_steps">
            <column name="job_name" value="WORKING_CAPITAL_LOAN_CLOSE_OF_BUSINESS"/>
            <column name="step_name" value="WC_DELINQUENCY_RANGE_SCHEDULE"/>
            <column name="step_order" value="2"/>
        </insert>
    </changeSet>

    <!-- Add READ_WORKINGCAPITALLOAN permission -->
    <changeSet author="fineract" id="wcl-0014-7">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM m_permission WHERE code = 'READ_WORKINGCAPITALLOAN'</sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="READ_WORKINGCAPITALLOAN"/>
            <column name="entity_name" value="WORKINGCAPITALLOAN"/>
            <column name="action_name" value="READ"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>

</databaseChangeLog>
